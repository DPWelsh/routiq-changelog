---
interface Props {
  category: 'feature' | 'improvement' | 'fix' | 'docs' | 'announcement';
}

const { category } = Astro.props;

/*
 * V3 palette — no blue. Differentiation via clay tints + stone neutrals.
 */
const styles: Record<Props['category'], string> = {
  feature:
    'bg-[color-mix(in_oklch,var(--color-clay)_18%,var(--color-cream))] text-[var(--color-clay-deep)] border-[color-mix(in_oklch,var(--color-clay)_55%,transparent)]',
  improvement:
    'bg-[color-mix(in_oklch,var(--color-stone)_55%,var(--color-cream))] text-[var(--color-fg)] border-[var(--color-stone-dim)]',
  fix:
    'bg-[color-mix(in_oklch,var(--color-clay)_10%,var(--color-cream))] text-[var(--color-clay-deep)] border-[color-mix(in_oklch,var(--color-clay)_35%,transparent)]',
  docs:
    'bg-[var(--color-cream-dim)] text-[var(--color-fg-muted)] border-[var(--color-border)]',
  announcement:
    'bg-[var(--color-clay)] text-[var(--color-cream)] border-[var(--color-clay)]',
};

const labels: Record<Props['category'], string> = {
  feature: 'Feature',
  improvement: 'Improvement',
  fix: 'Fix',
  docs: 'Docs',
  announcement: 'Announcement',
};
---
<span
  class:list={[
    'inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-medium border tracking-wide',
    styles[category],
  ]}
>
  {labels[category]}
</span>
