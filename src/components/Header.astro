---
const links = [
  { href: '/', label: 'Changelog' },
  { href: '/roadmap', label: 'Roadmap' },
];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="border-b border-[var(--color-border-soft)] bg-[var(--color-cream)]">
  <div class="mx-auto max-w-5xl px-5 sm:px-8 py-5 sm:py-6 flex items-center justify-between gap-4">
    <a href="/" class="flex items-baseline gap-3" aria-label="Routiq Changelog home">
      <img
        src="/routiq-wordmark-blackberry.svg"
        alt="routiq."
        class="h-5 sm:h-[22px] w-auto"
        width="120"
        height="32"
      />
      <span class="text-[var(--color-fg-subtle)] text-xs sm:text-sm italic font-[var(--font-display)] hidden sm:inline">
        / changelog
      </span>
    </a>
    <nav class="flex items-center gap-5 sm:gap-7 text-sm">
      {links.map((link) => {
        const active =
          link.href === '/'
            ? pathname === '/' || pathname.startsWith('/changelog')
            : pathname === link.href || pathname.startsWith(link.href);
        return (
          <a
            href={link.href}
            class:list={[
              'transition-colors',
              active
                ? 'text-[var(--color-fg)] underline decoration-[var(--color-clay)] decoration-2 underline-offset-[6px]'
                : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]',
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="https://routiq.ai"
        class="text-[var(--color-fg-muted)] hover:text-[var(--color-clay)] transition-colors hidden sm:inline"
      >
        routiq.ai &rarr;
      </a>
    </nav>
  </div>
</header>
