---
const links = [
  { href: '/', label: 'Changelog' },
  { href: '/roadmap', label: 'Roadmap' },
];
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="border-b border-[var(--color-border)]">
  <div class="mx-auto max-w-3xl px-5 py-5 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3 group" aria-label="Routiq Changelog home">
      <img
        src="/routiq-wordmark-cloud.svg"
        alt="routiq."
        class="h-5 sm:h-[22px] w-auto"
        width="120"
        height="32"
      />
      <span class="text-[var(--color-fg-subtle)] text-sm sm:text-base hidden sm:inline">
        / changelog
      </span>
    </a>
    <nav class="flex items-center gap-4 sm:gap-6 text-sm">
      {links.map(link => {
        const active =
          link.href === '/'
            ? pathname === '/' || pathname.startsWith('/changelog')
            : pathname === link.href || pathname.startsWith(link.href);
        return (
          <a
            href={link.href}
            class:list={[
              'transition-colors',
              active
                ? 'text-[var(--color-fg)]'
                : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]',
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="https://routiq.ai"
        class="text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors hidden sm:inline"
      >
        routiq.ai &rarr;
      </a>
    </nav>
  </div>
</header>
