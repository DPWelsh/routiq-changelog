---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('changelog', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  ogImage={`/og/changelog/${entry.id}.png`}
>
  <a href="/" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">
    &larr; All changes
  </a>

  <article class="mt-6">
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-fg-muted)]">
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
        <CategoryBadge category={entry.data.category} />
      </div>
      <h1 class="display mt-4 text-4xl sm:text-5xl">
        {entry.data.title}
      </h1>
      {entry.data.summary && (
        <p class="mt-3 text-lg text-[var(--color-fg-muted)] leading-relaxed">
          {entry.data.summary}
        </p>
      )}
    </header>

    <div class="prose-routiq">
      <Content />
    </div>
  </article>
</BaseLayout>
