---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('changelog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = entries[0];
const rest = entries.slice(1);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const shortDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

const categoryAccent: Record<string, string> = {
  feature: 'var(--color-clay)',
  improvement: 'var(--color-stone-dim)',
  fix: 'var(--color-clay-deep)',
  docs: 'var(--color-stone)',
  announcement: 'var(--color-clay)',
};

// Editorial cadence: hero on cream, then alternating dark / cream-dim / cream / stone
const bandFor = (idx: number): 'dark' | 'cream-dim' | 'cream' | 'stone' => {
  const rhythm: Array<'dark' | 'cream-dim' | 'cream' | 'stone'> = [
    'dark',
    'cream-dim',
    'cream',
    'stone',
    'dark',
    'cream',
    'cream-dim',
    'stone',
  ];
  return rhythm[idx % rhythm.length];
};
---
<BaseLayout title="Routiq Changelog" fullBleed>
  {/* ─────────────────────────  HERO  ───────────────────────── */}
  <section class="spread spread-cream">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <p class="eyebrow mb-6">/ Changelog</p>
      <h1 class="display text-[clamp(2.5rem,11vw,7rem)] leading-[1.05] sm:leading-[0.95] tracking-tight max-w-4xl">
        What we<span class="display-italic text-[var(--color-clay)]">’ve</span> shipped.
      </h1>
      <p class="mt-8 sm:mt-10 text-lg sm:text-xl text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
        Updates from the team building Routiq — the AI reception assistant for clinics that takes patient retention from accidental to predictable.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
        <a
          href="/roadmap"
          class="inline-flex items-center gap-1.5 text-[var(--color-clay)] hover:text-[var(--color-clay-deep)] transition-colors underline decoration-[var(--color-clay)]/40 decoration-1 underline-offset-4"
        >
          See the roadmap &rarr;
        </a>
        <span class="text-[var(--color-fg-subtle)]">·</span>
        <a
          href="/feed.xml"
          class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors"
        >
          RSS feed
        </a>
        <span class="text-[var(--color-fg-subtle)]">·</span>
        <a
          href="https://github.com/DPWelsh/routiq-changelog"
          class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors"
        >
          GitHub
        </a>
      </div>

      {/* Ship cadence ribbon */}
      <div class="mt-16 sm:mt-20 grid grid-cols-2 sm:grid-cols-4 gap-px bg-[var(--color-border-soft)] border border-[var(--color-border-soft)] rounded-lg overflow-hidden">
        <div class="bg-[var(--color-cream)] px-5 py-5">
          <p class="eyebrow-muted text-[10px]">Entries shipped</p>
          <p class="display text-3xl mt-1 tabular-nums">{entries.length}</p>
        </div>
        <div class="bg-[var(--color-cream)] px-5 py-5">
          <p class="eyebrow-muted text-[10px]">Latest</p>
          <p class="display text-3xl mt-1">{featured ? shortDate(featured.data.date) : '—'}</p>
        </div>
        <div class="bg-[var(--color-cream)] px-5 py-5">
          <p class="eyebrow-muted text-[10px]">Last 30 days</p>
          <p class="display text-3xl mt-1 tabular-nums">
            {entries.filter((e) => (Date.now() - e.data.date.valueOf()) < 30 * 24 * 60 * 60 * 1000).length}
          </p>
        </div>
        <div class="bg-[var(--color-cream)] px-5 py-5">
          <p class="eyebrow-muted text-[10px]">Category</p>
          <p class="display text-3xl mt-1">{featured ? featured.data.category.replace(/^./, (c) => c.toUpperCase()) : '—'}</p>
        </div>
      </div>
    </div>
  </section>

  {/* ─────────────────────────  FEATURED  ───────────────────────── */}
  {featured && (
    <section class="spread spread-cream-dim relative">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <div class="flex items-baseline justify-between mb-10 sm:mb-12">
          <p class="eyebrow">/ Latest release</p>
          <span class="eyebrow-muted text-[10px]">01 / {entries.length.toString().padStart(2, '0')}</span>
        </div>

        <article class="bg-[var(--color-cream)] rounded-2xl overflow-hidden shadow-[0_2px_30px_-12px_rgba(26,28,18,0.18)] grid md:grid-cols-[1fr_320px]">
          {/* Body */}
          <div class="relative pl-8 sm:pl-10 pr-6 sm:pr-10 py-10 sm:py-14">
            {/* Accent stripe */}
            <span
              class="absolute left-0 top-8 bottom-8 w-[3px] rounded-r-sm"
              style={`background:${categoryAccent[featured.data.category]}`}
              aria-hidden="true"
            />
            <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-fg-muted)] mb-5">
              <time datetime={featured.data.date.toISOString()} class="font-medium tabular-nums">
                {formatDate(featured.data.date)}
              </time>
              <span class="text-[var(--color-fg-subtle)]">·</span>
              <CategoryBadge category={featured.data.category} />
            </div>
            <h2 class="display text-[clamp(2rem,5vw,3.5rem)] leading-[1.05] tracking-tight">
              <a
                href={`/changelog/${featured.id}`}
                class="hover:text-[var(--color-clay-deep)] transition-colors"
              >
                {featured.data.title}
              </a>
            </h2>
            {featured.data.summary && (
              <p class="mt-6 text-[17px] sm:text-[18px] text-[var(--color-fg-muted)] leading-[1.65] max-w-[60ch]">
                {featured.data.summary}
              </p>
            )}
            <a
              href={`/changelog/${featured.id}`}
              class="mt-8 inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-deep)] transition-colors group"
            >
              Read the full release
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
            </a>
          </div>

          {/* Stats panel */}
          {featured.data.stats && featured.data.stats.length > 0 && (
            <aside class="bg-[var(--color-blackberry)] text-[var(--color-cream)] px-7 sm:px-8 py-10 sm:py-14 grid grid-cols-2 gap-x-5 gap-y-8 content-start">
              <p class="col-span-2 text-[10px] uppercase tracking-[0.22em] text-[var(--color-on-dark-muted)] font-medium">
                / By the numbers
              </p>
              {featured.data.stats.map((stat) => (
                <div>
                  <p class="display text-[clamp(1.5rem,3vw,2.25rem)] leading-none tracking-tight text-[var(--color-clay)]">
                    {stat.value}
                  </p>
                  <p class="mt-2 text-[12px] text-[var(--color-on-dark-muted)] leading-[1.35]">
                    {stat.label}
                  </p>
                </div>
              ))}
            </aside>
          )}
        </article>
      </div>
    </section>
  )}

  {/* ─────────────────────────  REST OF ENTRIES — alternating bands  ───────────────────────── */}
  {rest.length > 0 && (
    <section>
      <div class="mx-auto max-w-6xl px-5 sm:px-8 pt-20 sm:pt-28">
        <div class="flex items-baseline justify-between mb-12 pb-6 border-b border-[var(--color-stone-dim)]">
          <h2 class="display text-3xl sm:text-4xl">Previously</h2>
          <span class="eyebrow-muted">{rest.length.toString().padStart(2, '0')} more</span>
        </div>
      </div>

      <ol class="space-y-0">
        {rest.map((entry, idx) => {
          const band = bandFor(idx);
          const isDark = band === 'dark';
          const bandClass =
            band === 'dark'
              ? 'bg-[var(--color-blackberry)] text-[var(--color-cream)]'
              : band === 'cream-dim'
                ? 'bg-[var(--color-cream-dim)]'
                : band === 'stone'
                  ? 'bg-[color-mix(in_oklch,var(--color-stone)_45%,var(--color-cream))]'
                  : 'bg-[var(--color-cream)]';
          const eyebrowClass = isDark
            ? 'text-[var(--color-on-dark-muted)]'
            : 'text-[var(--color-fg-muted)]';
          const subtleClass = isDark
            ? 'text-[var(--color-on-dark-muted)]'
            : 'text-[var(--color-fg-subtle)]';
          const titleHover = isDark
            ? 'hover:text-[var(--color-clay)]'
            : 'hover:text-[var(--color-clay-deep)]';
          const summaryColor = isDark
            ? 'text-[color-mix(in_oklch,var(--color-cream)_75%,transparent)]'
            : 'text-[var(--color-fg-muted)]';
          const statValueColor = 'text-[var(--color-clay)]';
          const statLabelColor = isDark
            ? 'text-[var(--color-on-dark-muted)]'
            : 'text-[var(--color-fg-muted)]';

          return (
            <li class={`${bandClass} relative`}>
              <article class="mx-auto max-w-6xl px-5 sm:px-8 py-16 sm:py-24 relative">
                {/* Accent stripe */}
                <span
                  class="absolute left-0 top-16 sm:top-24 bottom-16 sm:bottom-24 w-[3px] rounded-r-sm"
                  style={`background:${categoryAccent[entry.data.category]}`}
                  aria-hidden="true"
                />
                <div class="pl-6 sm:pl-10 grid md:grid-cols-[1fr_minmax(0,280px)] gap-x-10 gap-y-8 md:gap-x-16 items-start">
                  <div>
                    <div class={`flex flex-wrap items-center gap-3 text-sm mb-4 ${eyebrowClass}`}>
                      <time datetime={entry.data.date.toISOString()} class="font-medium tabular-nums">
                        {formatDate(entry.data.date)}
                      </time>
                      <span class={subtleClass}>·</span>
                      <CategoryBadge category={entry.data.category} />
                    </div>
                    <h3 class={`display text-[clamp(1.65rem,3.4vw,2.5rem)] leading-[1.08] tracking-tight ${titleHover} transition-colors`}>
                      <a href={`/changelog/${entry.id}`}>{entry.data.title}</a>
                    </h3>
                    {entry.data.summary && (
                      <p class={`mt-5 text-[16px] sm:text-[17px] leading-[1.65] max-w-[58ch] ${summaryColor}`}>
                        {entry.data.summary}
                      </p>
                    )}
                    <a
                      href={`/changelog/${entry.id}`}
                      class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-deep)] transition-colors group"
                    >
                      Read the full release
                      <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
                    </a>
                  </div>

                  {/* Stats grid */}
                  {entry.data.stats && entry.data.stats.length > 0 && (
                    <aside class="grid grid-cols-2 gap-x-5 gap-y-6 self-start md:pt-2">
                      {entry.data.stats.map((stat) => (
                        <div>
                          <p class={`display text-[clamp(1.35rem,2.5vw,1.75rem)] leading-none tracking-tight ${statValueColor}`}>
                            {stat.value}
                          </p>
                          <p class={`mt-2 text-[11.5px] leading-[1.4] ${statLabelColor}`}>
                            {stat.label}
                          </p>
                        </div>
                      ))}
                    </aside>
                  )}
                </div>
              </article>
            </li>
          );
        })}
      </ol>
    </section>
  )}

  {entries.length === 0 && (
    <section class="spread spread-cream">
      <div class="mx-auto max-w-3xl px-5 sm:px-8">
        <p class="text-[var(--color-fg-muted)]">No entries yet. Check back soon.</p>
      </div>
    </section>
  )}
</BaseLayout>
