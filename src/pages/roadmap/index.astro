---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('roadmap');

const ordered = ['now', 'next', 'later', 'shipped'] as const;
type Status = (typeof ordered)[number];

const grouped = ordered.map((status) => ({
  status,
  items: entries
    .filter((e) => e.data.status === status)
    .sort((a, b) => a.data.order - b.data.order),
}));

const groupHeadings: Record<Status, { title: string; blurb: string }> = {
  now: {
    title: 'Now',
    blurb: 'What we’re actively building. These are the conversations the team has open right now.',
  },
  next: {
    title: 'Next',
    blurb: 'On deck. Designed, scoped, starting soon — unless something more urgent jumps the queue.',
  },
  later: {
    title: 'Later',
    blurb: 'Planned but not yet started. Worth doing; not yet at the front of the queue.',
  },
  shipped: {
    title: 'Shipped',
    blurb: 'Done. Live in production. Listed here so the throughline of how Routiq evolved stays visible.',
  },
};

const accentBar: Record<Status, string> = {
  now: 'bg-[var(--color-clay)]',
  next: 'bg-[var(--color-prompt)]',
  later: 'bg-[var(--color-border-strong)]',
  shipped: 'bg-[var(--color-prompt)]',
};

const accentText: Record<Status, string> = {
  now: 'text-[var(--color-clay)]',
  next: 'text-[var(--color-prompt)]',
  later: 'text-[var(--color-fg-muted)]',
  shipped: 'text-[var(--color-prompt)]',
};

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const totalActive = grouped.find((g) => g.status === 'now')?.items.length ?? 0;
const totalNext = grouped.find((g) => g.status === 'next')?.items.length ?? 0;
---
<BaseLayout title="Roadmap" description="What Routiq is building next.">
  <header class="mb-16 sm:mb-20">
    <div class="flex items-baseline gap-3 text-sm text-[var(--color-fg-subtle)] mb-3">
      <span class="font-mono uppercase tracking-widest">/ roadmap</span>
    </div>
    <h1 class="display text-5xl sm:text-7xl uppercase">Roadmap</h1>
    <p class="mt-6 sm:mt-8 text-lg sm:text-xl text-[var(--color-fg)] leading-relaxed max-w-2xl">
      What we’re building at Routiq, organised by where it sits in the queue. We update this as plans evolve — dates are intentionally absent because deadlines on a public roadmap age badly.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-5 text-sm">
      <div class="flex items-baseline gap-2">
        <span class="text-[var(--color-clay)] font-mono text-base">{totalActive}</span>
        <span class="text-[var(--color-fg-muted)]">in progress</span>
      </div>
      <span class="text-[var(--color-fg-subtle)]">·</span>
      <div class="flex items-baseline gap-2">
        <span class="text-[var(--color-prompt)] font-mono text-base">{totalNext}</span>
        <span class="text-[var(--color-fg-muted)]">on deck</span>
      </div>
      <span class="text-[var(--color-fg-subtle)]">·</span>
      <a href="/" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">
        Recent changelog &rarr;
      </a>
    </div>
  </header>

  <div class="space-y-20 sm:space-y-24">
    {grouped.map(({ status, items }) =>
      items.length > 0 && (
        <section>
          {/* Section header */}
          <div class="border-t border-[var(--color-border)] pt-10 mb-10">
            <div class="flex items-baseline justify-between flex-wrap gap-4 mb-3">
              <div class="flex items-baseline gap-4">
                <h2 class="display text-3xl sm:text-5xl uppercase">
                  {groupHeadings[status].title}
                </h2>
                <span class={`font-mono text-sm ${accentText[status]}`}>
                  {items.length.toString().padStart(2, '0')}
                </span>
              </div>
              <StatusBadge status={status} />
            </div>
            <p class="text-sm text-[var(--color-fg-muted)] max-w-xl leading-relaxed">
              {groupHeadings[status].blurb}
            </p>
          </div>

          {/* Cards */}
          <ol class="space-y-3 sm:space-y-4">
            {items.map((item, idx) => (
              <li>
                <a
                  href={`/roadmap/${item.id}`}
                  class="group relative block border border-[var(--color-border)] rounded-xl overflow-hidden bg-[var(--color-bg)] hover:bg-[var(--color-bg-elev)] hover:border-[var(--color-border-strong)] transition-all duration-200"
                >
                  {/* Left accent rail */}
                  <span
                    aria-hidden="true"
                    class:list={[
                      'absolute left-0 top-0 bottom-0 w-[3px] transition-all duration-200',
                      accentBar[status],
                      'group-hover:w-[5px]',
                    ]}
                  />

                  <div class="pl-6 pr-5 py-5 sm:py-6 sm:pl-8">
                    <div class="flex items-baseline gap-4 mb-2">
                      <span class={`font-mono text-xs sm:text-sm ${accentText[status]} tracking-wider`}>
                        {String(idx + 1).padStart(2, '0')}
                      </span>
                      <h3 class="display-md text-lg sm:text-xl uppercase tracking-tight group-hover:text-[var(--color-clay)] transition-colors flex-1">
                        {item.data.title}
                      </h3>
                    </div>

                    <p class="text-sm sm:text-[15px] text-[var(--color-fg-muted)] leading-relaxed pl-[3.25rem]">
                      {item.data.summary}
                    </p>

                    <div class="mt-4 pl-[3.25rem] flex items-center gap-3 text-xs">
                      <span class="text-[var(--color-fg-subtle)]">
                        Updated {formatDate(item.data.updated)}
                      </span>
                      <span aria-hidden="true" class="text-[var(--color-fg-subtle)]">·</span>
                      <span class={`${accentText[status]} opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0 transition-all duration-200`}>
                        Read more &rarr;
                      </span>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ol>
        </section>
      )
    )}

    {grouped.every((g) => g.items.length === 0) && (
      <p class="text-[var(--color-fg-muted)]">Roadmap is being populated. Check back soon.</p>
    )}
  </div>
</BaseLayout>
