---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('roadmap');

const ordered = ['now', 'next', 'later', 'shipped'] as const;
type Status = (typeof ordered)[number];

const grouped = ordered.map((status) => ({
  status,
  items: entries
    .filter((e) => e.data.status === status)
    .sort((a, b) => a.data.order - b.data.order),
}));

const spreadMeta: Record<Status, {
  index: string;
  eyebrow: string;
  headline: string;
  headlineAccent: string;
  blurb: string;
  anchor: string;
  bg: string;
  fg: string;
  fgMuted: string;
  rule: string;
  accentText: string;
  itemBorder: string;
  itemHover: string;
}> = {
  now: {
    index: '01',
    eyebrow: 'Phase 01 / In progress',
    headline: 'Now',
    headlineAccent: '.',
    blurb: 'What we’re actively building. The team has these open right now.',
    anchor: 'NOW',
    bg: 'bg-[var(--color-cream)]',
    fg: 'text-[var(--color-fg)]',
    fgMuted: 'text-[var(--color-fg-muted)]',
    rule: 'bg-[var(--color-clay)]',
    accentText: 'text-[var(--color-clay)]',
    itemBorder: 'border-[var(--color-border)]',
    itemHover: 'hover:bg-[var(--color-cream-dim)] hover:border-[var(--color-stone-dim)]',
  },
  next: {
    index: '02',
    eyebrow: 'Phase 02 / On deck',
    headline: 'Next',
    headlineAccent: '.',
    blurb: 'Designed, scoped, starting soon — unless something more urgent jumps the queue.',
    anchor: 'NEXT',
    bg: 'bg-[var(--color-cream-dim)]',
    fg: 'text-[var(--color-fg)]',
    fgMuted: 'text-[var(--color-fg-muted)]',
    rule: 'bg-[var(--color-clay-deep)]',
    accentText: 'text-[var(--color-clay-deep)]',
    itemBorder: 'border-[var(--color-stone-dim)]',
    itemHover: 'hover:bg-[var(--color-cream)] hover:border-[var(--color-border-strong)]',
  },
  later: {
    index: '03',
    eyebrow: 'Phase 03 / Planned',
    headline: 'Later',
    headlineAccent: '.',
    blurb: 'Worth doing; not yet at the front of the queue.',
    anchor: 'LATER',
    bg: 'bg-[var(--color-stone)]',
    fg: 'text-[var(--color-fg)]',
    fgMuted: 'text-[var(--color-fg-muted)]',
    rule: 'bg-[var(--color-blackberry)]',
    accentText: 'text-[var(--color-fg)]',
    itemBorder: 'border-[var(--color-stone-dim)]',
    itemHover: 'hover:bg-[var(--color-cream-dim)] hover:border-[var(--color-border-strong)]',
  },
  shipped: {
    index: '04',
    eyebrow: 'Phase 04 / Done',
    headline: 'Shipped',
    headlineAccent: '.',
    blurb: 'Live in production. Listed so the throughline of how Routiq evolved stays visible.',
    anchor: 'SHIPPED',
    bg: 'bg-[var(--color-blackberry)]',
    fg: 'text-[var(--color-cream)]',
    fgMuted: 'text-[var(--color-on-dark-muted)]',
    rule: 'bg-[var(--color-clay)]',
    accentText: 'text-[var(--color-clay)]',
    itemBorder: 'border-[var(--color-on-dark-border)]',
    itemHover: 'hover:bg-[color-mix(in_oklch,var(--color-cream)_4%,var(--color-blackberry))] hover:border-[color-mix(in_oklch,var(--color-cream)_18%,transparent)]',
  },
};

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const totalActive = grouped.find((g) => g.status === 'now')?.items.length ?? 0;
const totalNext = grouped.find((g) => g.status === 'next')?.items.length ?? 0;
const totalShipped = grouped.find((g) => g.status === 'shipped')?.items.length ?? 0;
---
<BaseLayout
  title="Roadmap"
  description="What Routiq is building next."
  fullBleed
>
  {/* Hero spread */}
  <section class="spread spread-cream">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <p class="eyebrow mb-6">/ Roadmap</p>
      <h1 class="display text-[clamp(2.5rem,11vw,7rem)] leading-[1.05] sm:leading-[0.95] tracking-tight max-w-4xl">
        What we’re building<span class="display-italic text-[var(--color-clay)]">,</span> in order.
      </h1>
      <p class="mt-8 sm:mt-10 text-lg sm:text-xl text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
        Organised by where it sits in the queue. We update this as plans evolve — dates are intentionally absent because deadlines on a public roadmap age badly.
      </p>

      {/* Stat row */}
      <dl class="mt-12 sm:mt-16 grid grid-cols-3 gap-6 sm:gap-12 max-w-2xl">
        <div>
          <dt class="eyebrow-muted mb-2">In progress</dt>
          <dd class="display-light text-4xl sm:text-5xl text-[var(--color-clay)]">{totalActive.toString().padStart(2, '0')}</dd>
        </div>
        <div>
          <dt class="eyebrow-muted mb-2">On deck</dt>
          <dd class="display-light text-4xl sm:text-5xl text-[var(--color-fg)]">{totalNext.toString().padStart(2, '0')}</dd>
        </div>
        <div>
          <dt class="eyebrow-muted mb-2">Shipped</dt>
          <dd class="display-light text-4xl sm:text-5xl text-[var(--color-fg)]">{totalShipped.toString().padStart(2, '0')}</dd>
        </div>
      </dl>
    </div>
  </section>

  {/* Phase spreads */}
  {grouped.map(({ status, items }) =>
    items.length > 0 && (
      <section class:list={["spread relative overflow-hidden", spreadMeta[status].bg]}>
        <div class={"mx-auto max-w-5xl px-5 sm:px-8 relative " + spreadMeta[status].fg}>
          {/* Eyebrow + headline */}
          <div class="mb-12 sm:mb-16">
            <div class="flex items-center gap-3 mb-6">
              <span class={"h-[2px] w-12 " + spreadMeta[status].rule}></span>
              <p class:list={["eyebrow", spreadMeta[status].accentText]}>
                {spreadMeta[status].eyebrow}
              </p>
            </div>
            <h2 class="display text-[clamp(2.75rem,13vw,8rem)] leading-[1.05] sm:leading-[0.9] tracking-tight">
              {spreadMeta[status].headline}<span class:list={["display-italic", spreadMeta[status].accentText]}>{spreadMeta[status].headlineAccent}</span>
            </h2>
            <p class:list={["mt-6 sm:mt-8 text-base sm:text-lg leading-relaxed max-w-2xl", spreadMeta[status].fgMuted]}>
              {spreadMeta[status].blurb}
            </p>
          </div>

          {/* Items — editorial list, not cards */}
          <ol class="space-y-2 sm:space-y-3 relative">
            {items.map((item, idx) => (
              <li>
                <a
                  href={`/roadmap/${item.id}`}
                  class:list={[
                    "group block border rounded-md py-5 sm:py-6 px-5 sm:px-7 transition-all duration-200",
                    spreadMeta[status].itemBorder,
                    spreadMeta[status].itemHover,
                  ]}
                >
                  <div class="grid grid-cols-[3rem_1fr_auto] sm:grid-cols-[3.5rem_1fr_auto] gap-4 sm:gap-6 items-baseline">
                    <span class:list={["display-italic text-2xl sm:text-3xl", spreadMeta[status].accentText]}>
                      {String(idx + 1).padStart(2, '0')}
                    </span>
                    <div>
                      <h3 class="display text-xl sm:text-2xl tracking-tight leading-tight">
                        {item.data.title}
                      </h3>
                      <p class:list={["mt-2 text-sm sm:text-[15px] leading-relaxed max-w-2xl", spreadMeta[status].fgMuted]}>
                        {item.data.summary}
                      </p>
                    </div>
                    <span class:list={["text-xs hidden sm:inline-block whitespace-nowrap", spreadMeta[status].fgMuted]}>
                      Updated {formatDate(item.data.updated)}
                    </span>
                  </div>
                </a>
              </li>
            ))}
          </ol>

          {/* Big phase anchor at bottom — brand-book style */}
          <div class="mt-20 sm:mt-28 select-none pointer-events-none">
            <p class:list={[
              "display text-[clamp(3.5rem,18vw,14rem)] leading-[0.85] tracking-tighter opacity-[0.10] break-all",
              spreadMeta[status].fg,
            ]}>
              {spreadMeta[status].anchor}<span class:list={["display-italic", spreadMeta[status].accentText]} style="opacity: 1;">.</span>
            </p>
          </div>
        </div>
      </section>
    )
  )}

  {grouped.every((g) => g.items.length === 0) && (
    <section class="spread spread-cream">
      <div class="mx-auto max-w-5xl px-5 sm:px-8">
        <p class="text-[var(--color-fg-muted)]">Roadmap is being populated. Check back soon.</p>
      </div>
    </section>
  )}
</BaseLayout>
